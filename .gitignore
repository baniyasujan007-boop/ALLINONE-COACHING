# -----------------------------
# Environment Files And Secrets
# Ignore real environment files and credential material.
# Keep committed templates such as backend/.env.example.
# -----------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template

backend/.env

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
google-services.json
GoogleService-Info.plist

# -----------------------------
# Node.js / Express Backend
# Ignore installed packages, runtime output, and local upload data.
# Do not ignore package manifests or lockfiles.
# -----------------------------
node_modules/
backend/node_modules/

backend/uploads/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Flutter / Dart
# Ignore Flutter tool state and generated build artifacts for this app.
# Keep source, pubspec files, platform wrappers, and checked-in app assets.
# -----------------------------
flutter/.dart_tool/
flutter/.flutter-plugins
flutter/.flutter-plugins-dependencies
flutter/.pub/
flutter/build/
flutter/**/build/

flutter/android/.gradle/
flutter/android/local.properties
flutter/android/captures/

flutter/ios/Pods/
flutter/ios/.symlinks/
flutter/ios/Flutter/ephemeral/
flutter/ios/Flutter/App.framework
flutter/ios/Flutter/Flutter.framework
flutter/ios/Flutter/Generated.xcconfig
flutter/ios/Flutter/flutter_export_environment.sh
flutter/ios/Flutter/Flutter.podspec
flutter/ios/Flutter/.last_build_id

flutter/macos/Pods/
flutter/macos/Flutter/ephemeral/

# Desktop plugin registrants and generated CMake glue are generated locally.
flutter/linux/flutter/generated_plugin_registrant.cc
flutter/linux/flutter/generated_plugin_registrant.h
flutter/linux/flutter/generated_plugins.cmake
flutter/windows/flutter/generated_plugin_registrant.cc
flutter/windows/flutter/generated_plugin_registrant.h
flutter/windows/flutter/generated_plugins.cmake

# -----------------------------
# Build Output, Logs, And Temp Files
# Ignore transient output from local builds, tests, and tooling.
# -----------------------------
build/
dist/
coverage/
cache/
.cache/
.tmp/
tmp/
*.log
*.tmp
*.temp
*.pid
*.pid.lock
*.seed

# -----------------------------
# OS / IDE Files
# Ignore machine-specific editor settings and OS metadata.
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini

.idea/
flutter/.idea/
.vscode/
*.iml
*.suo
*.user
*.userossc
*.swp
*.swo

# -----------------------------
# Misc Local Artifacts
# Ignore merge leftovers and local history files.
# -----------------------------
*.orig
.history/
.buildlog/
